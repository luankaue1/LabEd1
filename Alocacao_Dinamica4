#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_NOME 100

int main() {
    int numPessoas;
    char **nomes;
    int *idades;
    printf("Digite o número de pessoas (máximo 100): ");
    scanf("%d", &numPessoas);
    if (numPessoas > 100) numPessoas = 100;
    nomes = (char**) malloc(numPessoas * sizeof(char*));
    for (int i=0; i < numPessoas; i++) {
        nomes[i] = (char*) malloc(MAX_NOME * sizeof(char));
    }
    idades = (int*) malloc(numPessoas * sizeof(int));
    for (int i=0; i < numPessoas; i++) {
        printf("Pessoa %d:\n", i+1);
        printf("Nome completo: ");
        getchar();
        fgets (nomes [i], MAX_NOME, stdin); 
        nomes [i] [strcspn (nomes[i], "\n")]='\0';
        printf("Idade: ");
        scanf("%d", &idades[i]);
    }
    printf("Lista de pessoas:\n");
    for (int i=0; i < numPessoas; i++) {
        printf("Nome: %s, Idade: %d\n", nomes[i], idades[i]);
    }
    for (int i=0; i < numPessoas; i++) {
        free(nomes[i]);
    }
    free(nomes);
    free(idades);
    return 0;
}
