#include <stdio.h>
#include <string.h>
#include <stdlib.h>

typedef struct {
    char nome[50];
    float salario;
    int identificador;
    char cargo[30];
} Funcionario;

void preencher_funcionario(Funcionario* f) {
    printf("Digite o nome: ");
    fgets(f->nome, 50, stdin);
    f->nome[strcspn(f->nome, "\n")] = 0;

    printf("Digite o salario: ");
    scanf("%f", &f->salario);

    printf("Digite o identificador: ");
    scanf("%d", &f->identificador);
    getchar();

    printf("Digite o cargo: ");
    fgets(f->cargo, 30, stdin);
    f->cargo[strcspn(f->cargo, "\n")] = 0;
}

void imprimir_funcionario(Funcionario* f) {
    printf("\n--- Dados do Funcionario ---\n");
    printf("Nome: %s\n", f->nome);
    printf("Salario: %.2f\n", f->salario);
    printf("ID: %d\n", f->identificador);
    printf("Cargo: %s\n", f->cargo);
}

void alterar_salario(Funcionario* f, float novo_salario) {
    f->salario = novo_salario;
}

void maior_menor_salario(Funcionario v[], int n) {
    int i;
    int maior = 0, menor = 0;

    for (i = 1; i < n; i++) {
        if (v[i].salario > v[maior].salario) {
            maior = i;
        }
        if (v[i].salario < v[menor].salario) {
            menor = i;
        }
    }

    printf("\nFuncionario com MAIOR salario:\n");
    printf("Cargo: %s | Salario: %.2f\n", v[maior].cargo, v[maior].salario);

    printf("\nFuncionario com MENOR salario:\n");
    printf("Cargo: %s | Salario: %.2f\n", v[menor].cargo, v[menor].salario);
}

int main() {
    int n, i;

    printf("Quantos funcionarios deseja cadastrar? ");
    scanf("%d", &n);
    getchar();

    Funcionario funcionarios[n];

    for (i = 0; i < n; i++) {
        printf("\nFuncionario %d:\n", i + 1);
        preencher_funcionario(&funcionarios[i]);
    }

    for (i = 0; i < n; i++) {
        imprimir_funcionario(&funcionarios[i]);
    }

    float novo;
    printf("\nDigite novo salario para o primeiro funcionario: ");
    scanf("%f", &novo);
    alterar_salario(&funcionarios[0], novo);

    printf("\nApós alteração:\n");
    imprimir_funcionario(&funcionarios[0]);

    maior_menor_salario(funcionarios, n);

    return 0;
}
