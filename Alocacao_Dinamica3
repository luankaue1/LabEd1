#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int n, **matriz;
    srand(time(NULL));
    printf("Digite a ordem da matriz quadrada(n): ");
    scanf("%d", &n);
    matriz = (int**) malloc(n * sizeof(int*));
    for (int i=0; i < n; i++) {
        matriz[i] = (int*) malloc(n * sizeof(int));
    }
    printf("Matriz %dx%d com números aleatórios (1-100):\n", n, n);
    for (int i=0; i < n; i++) {
        for (int j=0; j < n; j++) {
            matriz[i][j] = (rand() % 100) + 1;
            printf("%d ", matriz[i][j]);
        }
        printf("\n");
    }
    for (int i=0; i < n; i++) {
        free(matriz[i]);
    }
    free(matriz);
    return 0;
}