#include <stdio.h>
#include <stdlib.h>

int main() {
    int n, i;
    int *vetor;
    float soma = 0, media;
    printf("Digite o tamanho do vetor: ");
    scanf("%d", &n);
    vetor = (int *)malloc(n * sizeof(int));
    if (vetor == NULL) {
        printf("Erro de alocação!\n");
        return 1;
    }
    printf("Digite %d elementos:\n", n);
    for (i = 0; i < n; i++) {
        scanf("%d", (vetor + i));
    }
    for (i = 0; i < n; i++) {
        soma += *(vetor + i);
    }
    media = soma / n;
    printf("Média: %.2f\n", media);

    free(vetor);
    vetor = NULL;

    return 0;
}