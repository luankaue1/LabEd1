#include <stdio.h>

void inverter(int *v, int n) {
    int i, temp;
    for (i = 0; i < n / 2; i++) {
        temp = *(v + i);
        *(v + i) = *(v + n - 1 - i);
        *(v + n - 1 - i) = temp;
    }
}
int main() {
    int vet[] = {1, 2, 3, 4, 5};
    inverter(vet, 5);
    for(int i = 0; i < 5; i++) printf("%d ", vet[i]);
    printf("\n");
    return 0;
}